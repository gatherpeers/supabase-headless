# Environment variables for docker compose (see compose.yml).
# Copy to `.env`, then run `node generate-keys.mjs --update-env` to fill all secrets.
# Official Supabase reference: https://github.com/supabase/supabase/blob/master/docker/.env.example

# Optional: salt for opaque sb_* key checksums (generate-keys.mjs).
# PROJECT_REF_FOR_KEYS=

# ---
# GENERAL (gateway, auth URLs, path prefixes)
# ---
PUBLIC_API_DOMAIN=localhost
PUBLIC_API_URL=https://${PUBLIC_API_DOMAIN}
APP_DOMAIN=localhost
APP_URL=https://${APP_DOMAIN}
AUTH_PREFIX=/auth/v1
REST_PREFIX=/rest/v1
REALTIME_PREFIX=/realtime/v1
STORAGE_PREFIX=/storage/v1
FUNCTIONS_PREFIX=/functions/v1

# ---
# API KEYS & JWT SIGNING
# https://supabase.com/docs/guides/self-hosting/self-hosted-auth-keys
# Recommended: `node generate-keys.mjs --update-env` fills JWT/API keys and any empty infrastructure secrets below.
# Re-running rotates JWT/API material except JWT_SECRET (kept stable when already set).
# VPS without Node:
#   docker run --rm -v "${PWD}:/work" -w /work node:24.16.0-alpine node generate-keys.mjs --update-env
# ---
# HS256 symmetric secret. Auth refresh-token signing; also embedded in JWT_JWKS for legacy HS256 verification.
JWT_SECRET=
# Signing JWKs (EC private + symmetric). Auth (GOTRUE_JWT_KEYS).
JWT_KEYS=
# Verifying JWKS (EC public + symmetric). PostgREST, Realtime, Storage.
JWT_JWKS=
# Internal ES256 JWTs — gateway substitutes these for opaque keys before proxying. Never expose to clients.
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=
# Browser/mobile publishable key. Maps to the anon role.
SUPABASE_PUBLISHABLE_KEY=
# Server-only secret key. Maps to service_role and bypasses RLS; never expose to browsers or mobile apps.
SUPABASE_SECRET_KEY=
# Legacy HS256 JWT API keys. Gateway accepts these alongside sb_* keys. Also required for the Realtime container healthcheck (compose interpolates ANON_KEY).
ANON_KEY=
SERVICE_ROLE_KEY=
# JWT claims consumed by auth (GOTRUE_JWT_EXP / GOTRUE_JWT_AUD).
JWT_EXP=3600
JWT_AUD=authenticated
GOTRUE_JWT_ISSUER=${PUBLIC_API_URL}${AUTH_PREFIX}

# ---
# POSTGRESQL (db, db-migrate, postgres-meta)
# ---
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_WORK_MEM=6MB
# Log queries slower than this many milliseconds.
POSTGRES_LOG_MIN_DURATION_STATEMENT=200
DB_SHM_SIZE=1GB
# Role passwords (db/init.sql bootstrap).
AUTH_DB_PASSWORD=
STORAGE_DB_PASSWORD=

# ---
# SUPABASE AUTH (GOTRUE) — wired in compose.yml
# https://github.com/supabase/auth?tab=readme-ov-file#configuration
# ---
GOTRUE_URI_ALLOW_LIST=${APP_URL}/*
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_RATE_LIMIT_HEADER=X-Forwarded-For
GOTRUE_REQUEST_ID_HEADER=X-Request-ID
GOTRUE_SECURITY_REFRESH_TOKEN_ROTATION_ENABLED=true
# fatal, error, warn, info, debug
GOTRUE_LOG_LEVEL=warn

# ---
# REALTIME — wired in compose.yml
# https://github.com/supabase/realtime?tab=readme-ov-file#server-setup
# SELF_HOST_TENANT_NAME is set from PUBLIC_API_DOMAIN in compose.
# ---
SECRET_KEY_BASE=
# Exactly 16 characters.
REALTIME_DB_ENC_KEY=
# Max 63 chars total: supabase_realtime_messages_replication_slot_ (45) + suffix (≤18).
SLOT_NAME_SUFFIX=local
REALTIME_DASHBOARD_AUTH=basic_auth
REALTIME_DASHBOARD_USER=admin
REALTIME_DASHBOARD_PASSWORD=
# info, emergency, alert, critical, error, warning, notice, debug
REALTIME_LOG_LEVEL=warning

# ---
# POSTGREST (rest) — wired in compose.yml
# https://docs.postgrest.org/en/latest/references/configuration.html
# ---
# Schemas exposed via the Data API. Add `graphql_public` if you enable it.
PGRST_DB_SCHEMAS=public
PGRST_DB_ANON_ROLE=anon
PGRST_DB_MAX_ROWS=1000
PGRST_DB_POOL=20
PGRST_AUTH_USER=authenticator
PGRST_AUTH_PASSWORD=
# crit, error, warn, info, debug
PGRST_LOG_LEVEL=warn

# ---
# RUSTFS (S3) — wired in compose.yml
# ---
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
# debug, info, warn, error
RUST_LOG=warn

# ---
# IMGPROXY — wired in compose.yml
# https://docs.imgproxy.net/latest/configuration/options
# ---
S3_REGION=local
# error, warn, info, debug
IMGPROXY_LOG_LEVEL=warn
IMGPROXY_FAIL_ON_DEPRECATION=true

# ---
# STORAGE API — wired in compose.yml
# https://github.com/supabase/storage?tab=readme-ov-file#development
# ---
GLOBAL_S3_BUCKET=supabase-global
FILE_SIZE_LIMIT=52428800
# pino levels: trace, debug, info, warn, error, fatal, silent
STORAGE_LOG_LEVEL=warn

# ---
# EDGE FUNCTIONS — wired in compose.yml (keys only; SUPABASE_URL is http://gateway in compose)
# ---

# ---
# GATEWAY (Caddy) — wired in compose.yml
# ---
CADDY_CONTACT_EMAIL=admin@localhost
CORS_ALLOWED_ORIGIN=${APP_URL}
GATEWAY_RATE_LIMIT_EVENTS=100
GATEWAY_RATE_LIMIT_WINDOW=1s
# Public path for the Realtime admin UI (Caddy proxies {$REALTIME_DASHBOARD_PREFIX}/* -> realtime:4000).
REALTIME_DASHBOARD_PREFIX=/admin
# DEBUG, INFO, WARN, ERROR (Caddy log level)
CADDY_LOG_LEVEL=WARN